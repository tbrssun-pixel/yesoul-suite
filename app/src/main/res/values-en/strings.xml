    <string name="about_title">Owl Bike V1 Tracker</string>
    <string name="about_positioning">A free local-first workout tracker and diagnostics helper for Bike V1 / YS-003 owners.</string>
    <string name="privacy_title">Privacy</string>
    <string name="privacy_body">The app does not use accounts, cloud services, ads, analytics, or crash reporting. Workouts and diagnostic snapshots stay locally on the device. CSV/TCX export and diagnostics sharing only happen when you choose them through the Android share sheet.</string>
    <string name="permissions_title">Permissions</string>
    <string name="permissions_body">Bluetooth is required to find and connect to the bike. On Android 11 and lower, the system location permission is required for BLE scanning, but the app does not record coordinates and does not request background location.</string>
    <string name="release_scope_title">v1 scope</string>
    <string name="release_scope_body">v1 shows BLE/FTMS metrics, stores local history, exports CSV/TCX, and helps collect compatibility diagnostics. Automatic resistance control, Health Connect, Strava, cloud sync, and payments are not included in v1.</string>

